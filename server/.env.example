# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── URLs ────────────────────────────────────────────────────────────────────
# Public URL of this server — used in email links (verification, password reset)
SERVER_URL=http://localhost:4000
# Public URL of the frontend — used for CORS and redirect links
CLIENT_URL=http://localhost:3000

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Pooler URL — used by the app at runtime (PgBouncer, port 6543)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct URL — used by `prisma migrate deploy` (non-pooled, port 5432)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Supabase Storage ─────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=chat-files

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET=change_me_to_a_random_64_char_hex_string

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate keys: npx web-push generate-vapid-keys
VAPID_EMAIL=mailto:you@example.com
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=you@gmail.com
# For Gmail: use an App Password (Google Account → Security → App passwords)
MAIL_PASS=your_app_password
