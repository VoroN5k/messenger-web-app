

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}
enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  nickname  String    @unique
  password  String
  role      Role      @default(USER)
  avatarUrl String?
  statusEmoji String? // e.g. "😀"
  isEmailVerified Boolean @default(false)
  emailVerifyToken String?
  passwordResetToken String?
  passwordResetExpires DateTime?
  isOnline   Boolean   @default(false)
  lastSeen   DateTime @default(now())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  sessions  Session[]
  pushSubscriptions PushSubscription[]
  conversationMembers ConversationMember[]
  sentMessages      Message[]   @relation("MessageSender")
  reactions         Reaction[]
  sentFriendRequests Friendship[] @relation("FriendshipSender")
  receivedFriendRequests Friendship[] @relation("FriendshipReceiver")
  publicKey UserPublicKey?
  forwardedMessages Message[] @relation("MessageForwardUser")
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int
  refreshToken String   @unique
  userAgent    String?
  deviceName   String?
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model Conversation {
  id          Int              @id @default(autoincrement())
  type        ConversationType
  name        String?
  description String?
  avatarUrl   String?
  createdById Int?
  pinnedMessageId Int?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  members  ConversationMember[]
  messages Message[]

  @@index([createdById])
}

model ConversationMember {
  id             Int        @id @default(autoincrement())
  conversationId Int
  userId         Int
  role           MemberRole @default(MEMBER)
  joinedAt       DateTime   @default(now())
  lastReadAt     DateTime   @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             Int       @id @default(autoincrement())
  content        String    @db.Text @default("")
  createdAt      DateTime  @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?
  fileUrl        String?
  fileName       String?
  fileType       String?
  fileSize       Int?
  senderId       Int
  conversationId Int
  replyToId      Int?

  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  replyTo      Message?     @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]    @relation("MessageReplies")
  reactions    Reaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([conversationId, id])
}

model Reaction {
  id        Int      @id @default(autoincrement())
  emoji     String   @db.VarChar(10)
  userId    Int
  messageId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@index([messageId])
  @@index([userId])
}

model Friendship {
  id         Int              @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  sender   User @relation("FriendshipSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("FriendshipReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model UserPublicKey {
  id        Int      @id @default(autoincrement())
  userId    Int      @unique
  publicKey String   // base X25519 public key
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

