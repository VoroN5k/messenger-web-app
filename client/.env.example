# ─── Client (Next.js) ─────────────────────────────────────────────────────────
# All NEXT_PUBLIC_* vars are exposed to the browser and baked in at build time.

# In production set to '/api' so Next.js proxies it (fixes cross-domain cookies).
# In local dev, '/api' works too — Next.js rewrites to BACKEND_URL.
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# Backend URL used only by Next.js server-side rewrites (not exposed to browser).
BACKEND_URL=http://localhost:4000

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# Must match VAPID_PUBLIC_KEY in server/.env
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
